<!-- views/pages/index.ejs -->

<!DOCTYPE html>
<html lang="en">
<head>
    <% include ../partials/head %>
</head>
<body class="container">

    <header>
        <% include ../partials/header %>
    </header>

    <main>
        <div class="jumbotron">
            <h1>This is great</h1>
            <p>Welcome to templating using EJS</p>
        </div>

        <h2> <%= department.name %> / <%= category.name %> </h2>

        <ul>
          <li> <%= item.name %> </li>
          <li> <%= item.id %> </li>
          <li> <%= item.description %> </li>
          <li> <%= item.price %></li>
          <li> <%= item.seller %></li>
        </ul>

    </main>

    <footer>
        <% include ../partials/footer %>
    </footer>

</body>
</html>
